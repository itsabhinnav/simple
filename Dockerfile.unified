# =============================================================================
# Sakura - unified single-image build (frontend + backend).
#
# Stage 1 builds the static Angular SPA. Stage 2 installs Python deps and
# copies the built bundle into backend/static so Flask serves both /api and
# the SPA on the same origin.
#
# Build with corporate proxy support:
#   docker build \
#     --build-arg HTTPS_PROXY=http://user:pass@proxy.corp.local:8080 \
#     --build-arg HTTP_PROXY=http://user:pass@proxy.corp.local:8080 \
#     --build-arg NO_PROXY=localhost,127.0.0.1,.corp.local \
#     -f Dockerfile.unified -t sakura .
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: Angular build
# -----------------------------------------------------------------------------
FROM node:20-slim AS build-frontend

# Proxy plumbing - propagate to apt, npm, and Node TLS so corporate networks
# can pull packages. NO defaults: the build behaves identically to a no-proxy
# build when these are unset.
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ENV HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY} \
    http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    no_proxy=${NO_PROXY} \
    NPM_CONFIG_FETCH_RETRIES=5 \
    NPM_CONFIG_FETCH_RETRY_FACTOR=2

WORKDIR /app/frontend

COPY frontend/package*.json ./
RUN npm ci --no-audit --no-fund || npm install --no-audit --no-fund

COPY frontend/ .
RUN npm run build

# -----------------------------------------------------------------------------
# Stage 2: Python backend
# -----------------------------------------------------------------------------
FROM python:3.10-slim

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    ENVIRONMENT=production \
    FLASK_ENV=production \
    HOST=0.0.0.0 \
    PORT=5000 \
    ENABLE_NETWORK_RESTRICTIONS=strict \
    FORCE_HTTPS=false \
    SAKURA_LLM_ALLOW_EXTERNAL=false \
    SAKURA_LLM_ALLOW_REMOTE_OLLAMA=false \
    SAKURA_DISABLE_OLLAMA_SIDECAR=true \
    SAKURA_DISABLE_LIVE_INDEXER=false \
    OLLAMA_MODELS=/app/data/ollama/models \
    HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY} \
    http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    no_proxy=${NO_PROXY} \
    PIP_DEFAULT_TIMEOUT=120 \
    PIP_RETRIES=5

WORKDIR /app

# System runtime deps:
#   * curl, ca-certificates  - healthcheck + TLS roots
#   * libreoffice-core/calc/writer + poppler-utils - hybrid document parser
#     visual preprocessor (soffice xlsx/docx -> pdf -> pdftoppm -> png) used
#     by the Smart Import VLM pipeline. Without these the parser silently
#     falls back to deterministic-only mode with no page snapshots.
#   * fonts-dejavu-core   - LibreOffice headless needs at least one font
#     family to render snapshots; the alpine-style "no fonts" image yields
#     blank tiles.
#   * git  - retained for future Git-backed import flows. The local-only
#     HybridDatabaseService does NOT need it at runtime any more.
# psycopg2-binary ships pre-built manylinux wheels for amd64/arm64, so
# libpq-dev is no longer required in the runtime image.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
        libreoffice-core libreoffice-calc libreoffice-writer \
        poppler-utils fonts-dejavu-core \
 && rm -rf /var/lib/apt/lists/*

# Build pip --proxy args from the build-arg proxy (pip already honours env
# vars, but passing the flag is explicit and works even if env propagation
# is stripped by some BuildKit configurations).
COPY backend/requirements.txt .
RUN PIP_PROXY_ARG="" ; \
    if [ -n "$HTTPS_PROXY" ]; then PIP_PROXY_ARG="--proxy $HTTPS_PROXY" ; \
    elif [ -n "$HTTP_PROXY" ];  then PIP_PROXY_ARG="--proxy $HTTP_PROXY"  ; fi ; \
    pip install --no-cache-dir $PIP_PROXY_ARG --upgrade pip setuptools wheel \
 && pip install --no-cache-dir $PIP_PROXY_ARG -r requirements.txt

# Copy backend source.
COPY backend/ .

# Drop the built static SPA into backend/static so Flask serves it at /.
COPY --from=build-frontend /app/frontend/dist/frontend/browser ./static
RUN if [ ! -s ./static/index.html ] && [ -f ./static/index.csr.html ]; then \
        cp ./static/index.csr.html ./static/index.html ; \
    fi

# Persistent data lives here; mount a volume to keep the SQLite DB, the RAG
# vector index, uploaded specs, and (optionally) the bundled Ollama model
# blobs across container recreations (see docker-compose.yml).
#   data/local/dev/database  - primary SQLite (sakura_db.db)
#   data/local/dev/vectors   - RAG sidecar SQLite (sakura_vec.db) for sqlite-vec
#   data/ollama/models       - matches OLLAMA_MODELS env, only used when an
#                              external Ollama sidecar is started (off by default)
#   uploads/specs            - user-uploaded specification documents
RUN mkdir -p data/local/dev/database data/local/dev/vectors \
             data/ollama/models uploads/specs

EXPOSE 5000

# Liveness + readiness probe. Hits the /health endpoint Flask exposes.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl --fail --silent --show-error \
        "http://127.0.0.1:${PORT:-5000}/health" || exit 1

# run_server.py picks Gunicorn on Linux (here) automatically and runs the
# same bootstrap path as `python main.py` (DB init, master admin, etc).
CMD ["python", "run_server.py"]

{
  "environment": "development",
  "database": {
    "provider": "hybrid",
    "name": "sakura_db.db",
    "host": "localhost",
    "port": 5432,
    "username": "",
    "password": "",
    "schema": "public",
    "connection_pool_size": 10,
    "connection_timeout": 30,
    "ssl_enabled": false,
    "ssl_cert_path": null,
    "data_directory": "data/dev",
    "cache_directory": "data/cache/dev",
    "local_db_path": "data/local/local.db",
    "sync_interval": 300,
    "cache_expiry": 3600,
    "table_names": {
      "users": "users",
      "test_cases": "test_cases",
      "requirements": "requirements"
    }
  },
  "storage": {
    "provider": "git",
    "base_url": "https://gitlab.com/android-devops/sakura-db",
    "username": "admin",
    "password": "password",
    "repository": "android-devops/sakura-db",
    "branch": "main",
    "timeout": 30,
    "retry_attempts": 3,
    "retry_delay": 1.0,
    "verify_ssl": true,
    "api_version": "v1",
    "local_repo_path": "remote/dev",
    "data_path": "data/dev",
    "git_username": null,
    "git_token": null,
    "artifactory_repo_type": "generic-local"
  },
  "authentication": {
    "default_admin_username": "admin",
    "default_admin_password": "password",
    "default_admin_email": "admin@sakura.com",
    "session_timeout": 3600,
    "max_login_attempts": 5,
    "lockout_duration": 900,
    "reserved_usernames": ["admin", "root", "system", "administrator", "sa"],
    "min_password_length": 8,
    "require_special_chars": true,
    "require_numbers": true,
    "require_uppercase": true
  },
  "server": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": true,
    "mock_mode": true,
    "mock_server_port": 8080,
    "cors_origins": ["*"],
    "cors_methods": ["GET", "POST", "PUT", "DELETE"],
    "cors_headers": ["Content-Type", "Authorization"],
    "rate_limit_enabled": true,
    "rate_limit_requests": 100,
    "rate_limit_window": 3600
  },
  "logging": {
    "level": "DEBUG",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file_path": null,
    "max_file_size": 10485760,
    "backup_count": 5,
    "enable_console": true,
    "enable_file": false,
    "structured_logging": false,
    "log_json": false
  },
  "features": {
    "user_management": true,
    "test_case_management": true,
    "requirement_management": true,
    "git_integration": true,
    "artifactory_integration": false,
    "advanced_logging": false
  }
}

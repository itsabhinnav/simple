# =============================================================================
# Sakura runtime configuration
# Copy this file to `.env` (the setup scripts will do that for you and fill in
# secure values where they are missing) and tweak as needed.
# =============================================================================

# Application mode: "production" keeps Flask debug off and serves the built
# Angular bundle. Use "development" only when iterating on the backend.
ENVIRONMENT=production

# Bind address for the Flask/WSGI server. 0.0.0.0 makes it reachable on the
# LAN; switch to 127.0.0.1 to lock it down to the local machine.
HOST=0.0.0.0
PORT=5000

# Required secrets - the setup scripts generate strong defaults if missing.
JWT_SECRET_KEY=change-me
ENCRYPTION_KEY=change-me

# Comma-separated list of additional origins allowed by Flask-CORS.
# The bundled Angular frontend is served from the same origin, so this only
# matters when you want to talk to the API from another host.
ALLOWED_ORIGINS=http://localhost:5000

# Set to "true" to enable the socket allow-list in
# src/infrastructure/network_restrictor.py (blocks everything except Git
# remotes and localhost). Off by default for easier local deployment.
ENABLE_NETWORK_RESTRICTIONS=false

# Force HTTPS via Flask-Talisman. Leave false unless you terminate TLS in
# front of the app.
FORCE_HTTPS=false

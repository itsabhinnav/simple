# =============================================================================
# Sakura runtime configuration
# Copy this file to `.env` (the setup scripts will do that for you and fill in
# secure values where they are missing) and tweak as needed.
#
# Defaults below are tuned for a high-security on-prem deployment:
#   - bind to loopback only
#   - force HTTPS
#   - network restrictor on
# Loosen them only when you understand the impact.
# =============================================================================

# Application mode: "production" keeps Flask debug off and serves the built
# Angular bundle. Use "development" only when iterating on the backend.
ENVIRONMENT=production
FLASK_ENV=production

# Bind address for the Flask/WSGI server. 127.0.0.1 locks the API to the
# local machine; switch to 0.0.0.0 (or a specific LAN IP) only when you
# explicitly want the API reachable from other hosts.
HOST=127.0.0.1
PORT=5000

# Required secrets — REQUIRED in production; the app refuses to start without
# them. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"   # JWT_SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # ENCRYPTION_KEY
JWT_SECRET_KEY=
ENCRYPTION_KEY=

# Comma-separated list of additional origins allowed by Flask-CORS.
# The bundled Angular frontend is served from the same origin, so this only
# matters when you want to talk to the API from another host. Wildcard ("*")
# is rejected at startup when combined with credentialed CORS.
ALLOWED_ORIGINS=https://sakura.corp.example

# Network egress allow-list mode (src/infrastructure/network_restrictor.py).
#   strict     — loopback only (default; recommended for on-prem)
#   allow_lan  — loopback + RFC-1918 private ranges
#   off        — no restriction (NOT recommended; refused in production)
ENABLE_NETWORK_RESTRICTIONS=strict

# Force HTTPS via Flask-Talisman. Keep on unless TLS is terminated by a
# reverse proxy directly in front of the app on a trusted local socket.
FORCE_HTTPS=true

# External LLM provider gate. When false (default for on-prem), OpenAI and
# Anthropic providers are refused at registration time even if an API key is
# present in the environment. Local Ollama is unaffected.
SAKURA_LLM_ALLOW_EXTERNAL=false

# Allow the Ollama base_url to point outside the loopback range. Off by
# default — refused entirely when ENVIRONMENT=production.
SAKURA_LLM_ALLOW_REMOTE_OLLAMA=false

# Require a valid JWT on every /api/* route except login/signup. Default on.
# Set to false only for local backend development without auth.
SAKURA_REQUIRE_AUTH=true

# Server-side fetch of spec source_url values. Disabled by default (SSRF risk).
# Refused when ENVIRONMENT=production even if set to true.
# SAKURA_ALLOW_SPEC_URL_FETCH=false

# Explicit opt-in to widen outbound egress to RFC-1918 (NOT for production).
# SAKURA_ALLOW_LAN_EGRESS=false

# --- Docker LAN stack (docker-compose.yml) -----------------------------------
# TLS reverse proxy ports (nginx is the only service exposed to the LAN).
# NGINX_HTTPS_PORT=443
# NGINX_HTTP_PORT=80

# Local-only API observability (admin /api/admin/observability). No cloud telemetry.
SAKURA_ENABLE_OBSERVABILITY=true

# Optional IAM profiles (docker compose --profile iam / --profile edge-auth):
# KEYCLOAK_ADMIN_PASSWORD=
# AUTHELIA_JWT_SECRET=
# AUTHELIA_SESSION_SECRET=
# AUTHELIA_COOKIE_DOMAIN=sakura.corp.example

# --- Optional sidecars / background workers --------------------------------
# Bundled Ollama daemon (only present in the desktop installer build). The
# Docker images and the public source tree do NOT ship the multi-GB GGUF
# blobs, so the sidecar is off by default. Flip to "false" to spawn it when
# the vendored binary + models are present.
SAKURA_DISABLE_OLLAMA_SIDECAR=true

# RAG live indexer background thread. It polls database_metadata.version
# and re-embeds rows whose content hash changed so the in-app assistant
# always has fresh vectors. Disable only when you need to keep cold-start
# CPU footprint to an absolute minimum.
SAKURA_DISABLE_LIVE_INDEXER=false

# --- Optional local test automation bridge ---------------------------------
# Wire Sakura Execute buttons to a subprocess or loopback HTTP runner on
# the same machine. See backend/scripts/test_automation_runner.py for a stub.
# Add to config.yaml (not .env):
#   test_automation:
#     enabled: true
#     mode: subprocess          # subprocess | http
#     subprocess:
#       command: ["python", "scripts/test_automation_runner.py"]
#       working_directory: backend
#       timeout_seconds: 300
#       input_via: stdin_json    # stdin_json | args
#     http:
#       url: http://127.0.0.1:8765/execute
#       method: POST
#       timeout_seconds: 120

# Override the Ollama executable lookup (env var > config key >
# resources/ollama/ > PATH). Leave empty to use the auto-discovery order.
# SAKURA_OLLAMA_EXE=
# Override the model blob directory; defaults to
# %LOCALAPPDATA%\sakura\ollama\models on Windows and
# ~/.local/share/sakura/ollama/models elsewhere.
# OLLAMA_MODELS=
